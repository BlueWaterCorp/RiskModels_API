# RiskModels API Developer Portal — Environment Variables
# Copy to .env.local for local dev. Set in Vercel Dashboard for production.

# --- Python SDK / scripts (riskmodels-py, scripts/generate_readme_assets.py) ---
# Default API base is https://riskmodels.app/api. For local Next dev, uncomment:
# RISKMODELS_BASE_URL=http://localhost:3000/api
# Requires `npm run dev` and the same Supabase + API key setup your routes need.

# Supabase (public — safe in client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# App URL (production: https://riskmodels.app, preview: Vercel preview URL)
NEXT_PUBLIC_APP_URL=https://riskmodels.app

# Gateway auth for trusted server-to-server reads from Risk_Models
# Set in Doppler as RISKMODELS_API_SERVICE_KEY
RISKMODELS_API_SERVICE_KEY=rm_service_...

# Zarr on GCS (ERM3 history in local dev / non-Vercel): absolute path to the JSON key.
# Strongly recommended if your shell exports GOOGLE_APPLICATION_CREDENTIALS to another project —
# Next.js will not override an already-set env var from .env.local, but this name is app-specific.
# RISKMODELS_GCS_KEYFILE=/absolute/path/to/gcp-service-account-key.json

# Supabase (server-only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (server-only — NEVER expose to client)
STRIPE_SECRET_KEY=sk_live_...   # or sk_test_... for dev

# --- Email (Resend + React Email; low-balance and other transactional mail) ---
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="RiskModels <service@riskmodels.app>"
# Audit BCC (default resend@riskmodels.app). Set to 0 to disable.
# RESEND_BCC_EMAIL=resend@riskmodels.app

# Cron (Vercel): API key expiry reminder emails (GET /api/cron/notify-expiring-keys).
# Set in Vercel; Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=generate_a_long_random_string

# --- OpenAI (server-only — powers POST /api/chat and POST /api/landing/chat) ---
# The agentic risk analyst chat (floating bubble on every page) uses
# gpt-4o-mini with tool-calling against the ERM3 DAL. The main /api/chat
# route is billed per-token + per-tool; /api/landing/chat is a keyless
# MAG7-only demo proxy with a 10-msg/hour/IP throttle. Without this key,
# both routes return 503 and the chat bubble surfaces a friendly
# "not configured yet" message.
OPENAI_API_KEY=sk-...
